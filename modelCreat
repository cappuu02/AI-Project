import numpy as np
import tensorflow as tf
from tensorflow.keras import models, layers
from emnist import extract_training_samples, extract_test_samples

# carico il dataset con cifre
(train_images_digits, train_labels_digits) = extract_training_samples('digits')
(test_images_digits, test_labels_digits) = extract_test_samples('digits')

# carico il dataset con lettere
(train_images_letters, train_labels_letters) = extract_training_samples('letters')
(test_images_letters, test_labels_letters) = extract_test_samples('letters')

# concateno i dati
train_images = np.concatenate([train_images_digits, train_images_letters])
train_labels = np.concatenate([train_labels_digits, train_labels_letters])

test_images = np.concatenate([test_images_digits, test_images_letters])
test_labels = np.concatenate([test_labels_digits, test_labels_letters])

# normalizzo le immagini
train_images, test_images = train_images / 255.0, test_images / 255.0

# costruisco il modello della neural newtork CNN
model = models.Sequential([
    layers.Conv2D(32, (3, 3), activation='relu', input_shape=(28, 28, 1)),
    layers.MaxPooling2D((2, 2)),
    layers.Flatten(),
    layers.Dense(128, activation='relu'),
    layers.Dropout(0.5),
    layers.Dense(47, activation='softmax')
])

# compilo il modello
model.compile(optimizer='adam',
              loss='sparse_categorical_crossentropy',
              metrics=['accuracy'])

# addestro il modello
model.fit(train_images, train_labels, epochs=3, validation_data=(test_images, test_labels))

model.save("venv/share")

# Valuta il modello sul set di test
test_loss, test_accuracy = model.evaluate(test_images, test_labels)

print(f'Test Accuracy: {test_accuracy * 100:.2f}%')
print(f'Test Loss: {test_loss:.4f}')

# Fai predizioni su alcune immagini di test
predictions = model.predict(test_images)

# Puoi stampare le previsioni per una singola immagine di test
index_to_check = 0  # Sostituisci con l'indice desiderato
predicted_label = np.argmax(predictions[index_to_check])
true_label = test_labels[index_to_check]

print(f'Predicted Label: {predicted_label}')
print(f'True Label: {true_label}')

# Se vuoi visualizzare l'immagine, puoi farlo con matplotlib
import matplotlib.pyplot as plt

plt.imshow(test_images[index_to_check].reshape(28, 28), cmap='gray')
plt.show()
