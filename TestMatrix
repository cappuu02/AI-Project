def remove_grid(image):
    edges = cv2.Canny(image, 50, 200, apertureSize=3) #Carta
    #edges = cv2.Canny(image, 50, 700, apertureSize=3) #Digitale
    kernel = np.ones((5, 5), np.uint8)
    edges = cv2.morphologyEx(edges, cv2.MORPH_CLOSE, kernel)
    lines = cv2.HoughLinesP(edges, 0.1, np.pi / 180, threshold=100, minLineLength=150, maxLineGap=20)

    if lines is not None:
        for line in lines:
            x1, y1, x2, y2 = line[0]
            cv2.line(image, (x1, y1), (x2, y2), (255, 255, 255), 10)

    return image


# Widget per caricare e visualizzare l'immagine
def load_and_display_image(image_name):
    image = cv2.imread(image_name)
    image_without_grid = remove_grid(image)

    return image_without_grid


