    def ASTAR(problem, h=None):
        h = memoize(h or problem.h, 'h')
        return bestFirst_search_graph(problem, lambda node : h(node)+node.path_cost)



    #Funzione che Ritorna la posizione all'interno della matrice di S
    def find_initial_position(rooms):
        for row_idx, row in enumerate(rooms):
            for col_idx, cell in enumerate(row):
                if cell == "S":
                    position = (row_idx, col_idx)  # Aggiungi 1 agli indici per ottenere le coordinate basate su 1
                    return ("S", position)  # Ritorna una tupla con il simbolo e le coordinate

        return None

