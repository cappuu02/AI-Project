class Node:
    def __init__(self, robot_node, rooms, parent=None, action=None, path_cost=0):
        self.robot_node = robot_node
        self.rooms = rooms
        self.parent = parent
        self.action = action
        self.path_cost = path_cost

    def __repr__(self):
        return f"<Node {self.robot_node}, Action: {self.action}>"

    def generate_all_nodes(self, problem):
        all_nodes = []
        frontier = deque([self])

        while frontier:
            node = frontier.popleft()
            all_nodes.append(node)
            frontier.extend(node.expand(problem))

        return all_nodes

    def expand(self, problem):
      return [self.child_node(problem, action)
            for action in problem.actions(self.state)]



    def child_node(self, problem, action):
        next_state = problem.result(self, action)
        next_node = Node(next_state.robot_node, next_state.rooms, self, action,
                         problem.path_cost(self.path_cost, self, action, next_state))
        return next_node

    def solution(self):
        return [node.action for node in self.path()[1:]]

    def path(self):
        node, path_back = self, []
        while node:
            path_back.append(node)
            node = node.parent
        return list(reversed(path_back))

    def apply_action(self, action):
        new_node = Node(self.robot_node, [row[:] for row in self.rooms])
        robot_row, robot_col = self.robot_node

        if action == "clean":
            new_node.rooms[robot_row][robot_col] = 'C'
        elif action == "move_up":
            new_node.robot_node = (robot_row - 1, robot_col)
        elif action == "move_down":
            new_node.robot_node = (robot_row + 1, robot_col)
        elif action == "move_left":
            new_node.robot_node = (robot_row, robot_col - 1)
        elif action == "move_right":
            new_node.robot_node = (robot_row, robot_col + 1)

        return new_node

    def __hash__(self):
        return hash(self.state)



