        # Aggiorna l'euristica per ogni stanza della matrice
        # Calcolo l'euristica per ogni stanza rispetto ad una stanza sporca adiacente alla sorgente
        def h_update(self, next_room, node):
            h_values = [[None for _ in range(len(rooms[0]))] for _ in range(len(rooms))]

            # Trova una stanza sporca adiacente al nodo attuale
            dirty_rooms = []
            final_position = None
            nearest_dirty_room = None
            inaccessibile = False
            nearest_distance = math.inf
            deadend_rooms = [] # Stanze inaccessibili

            # Trova una stanza sporca adiacente al nodo attuale
            for row_idx, row in enumerate(node.rooms):
                for col_idx, cell in enumerate(row):
                    if cell == "D" or cell == "V":  # Verifica se la stanza è sporca
                        room = (row_idx, col_idx)
                        distance = calculate_distance(next_room, room)
                        
                        # Trova la stanza sporca adiacente con distanza minima
                        if distance < nearest_distance and next_room_deadend(node, room) == False:
                            nearest_distance = distance
                            nearest_dirty_room = room

                        # Trova la stanza sporca adiacente con distanza minima anche tra le stanze inaccessibili
                        if distance <= nearest_distance and next_room_deadend(node, room) == True:
                            nearest_distance = distance
                            nearest_dirty_room = room
                            deadend_rooms.append(room)

                        # Verifica se la stanza è inaccessibile
                        if distance < nearest_distance and next_room_deadend(node, room) == None:
                            print("!!!Stanza Inaccessibile: ", room)
                            inaccessibile = True
                            room_inaccessibile = room

                    if cell == "F":
                        final_position = (row_idx, col_idx)

            # Se la stanza è inaccessibile ma non ci sono stanze sporche adiacenti, utilizza la stanza inaccessibile
            if (inaccessibile == True and nearest_dirty_room == None):
                nearest_dirty_room = room_inaccessibile

            # Se ci sono stanze inaccessibili, cerca una stanza sporca adiacente anche tra le stanze inaccessibili
            if (deadend_rooms != None):
                for row_idx, row in enumerate(node.rooms):
                    for col_idx, cell in enumerate(row):
                        if cell == "D" or cell == "V":  # Verifica se la stanza è sporca
                            room = (row_idx, col_idx)

                            if (room in deadend_rooms):
                                distance = calculate_distance(next_room, room)

                                # Trova la stanza sporca adiacente con distanza minima anche tra le stanze inaccessibili
                                if distance <= nearest_distance:
                                    nearest_distance = distance
                                    nearest_dirty_room = room

            # Calcola l'euristica per ogni stanza rispetto ad una stanza sporca adiacente alla sorgente
            dirty_vacuumed = all(
                find_letter_position(node, row, col) not in ["D", "V"] for row in range(len(rooms)) for col in
                range(len(rooms[row])))

            if not dirty_vacuumed:
                for row_idx, row in enumerate(node.rooms):
                    for col_idx, cell in enumerate(row):
                        if cell == "X":
                            h_values[row_idx][col_idx] = math.inf

                        else:
                            distance = calculate_distance((row_idx, col_idx), nearest_dirty_room)
                            h_values[row_idx][col_idx] = distance

            # Se tutte le stanze sono pulite, calcola l'euristica rispetto alla posizione finale
            if dirty_vacuumed:
                for row_idx, row in enumerate(rooms):
                    for col_idx, cell in enumerate(row):
                        if cell == "X":
                            h_values[row_idx][col_idx] = math.inf

                        else:
                            h_values[row_idx][col_idx] = calculate_distance((row_idx, col_idx), final_position)

            return h_values

