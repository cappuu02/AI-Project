#Funzione che Ritorna la posizione all'interno della matrice di S
def find_initial_position(rooms):
    for row_idx, row in enumerate(rooms):
        for col_idx, cell in enumerate(row):
            if cell == "S":
                position = (row_idx, col_idx)  # Aggiungi 1 agli indici per ottenere le coordinate basate su 1
                return ("S", position)  # Ritorna una tupla con il simbolo e le coordinate

    return None

def find_letter_position(rooms, row, col):
    return rooms[row][col]

def update_letter_position(rooms, row, col, new_letter):
    rooms[row][col] = new_letter

def count_dirty_rooms(rooms):
    dirty_count = 0
    Vdirty_count = 0
    for row in rooms:
        for cell in row:
            if cell == "D":
                dirty_count += 1
            elif cell == "V":
                Vdirty_count += 3
    return dirty_count, Vdirty_count

def choose_search_algorithm(problema):
    valid_choices = {'bfs', 'a*','BFS','Bfs','A*','A','a'}
    while True:
        choice = input("Scegli l'algoritmo di ricerca (bfs o a*): ").strip().lower()
        if choice in valid_choices:
            if choice in ['bfs', 'BFS','Bfs']:
              return BFS(problema)
            if choice in ['a*','A*','A','a']:
              return A(problema)
        else:
            print("Scelta non valida. Riprova.")

