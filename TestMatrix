    class Node:
        def __init__(self, robot_node, room, rooms, parent = None, action = None, path_cost = 0, frontier = deque(), explored = set()):
            self.robot_node = robot_node
            self.room = room
            self.rooms = rooms
            self.parent = parent
            self.action = action
            self.path_cost = path_cost
            self.frontier = frontier or deque()
            self.explored = explored

        def __repr__(self):
            return f"<Node ('{self.robot_node}', {self.room}, {self.rooms})>"

        def expand(self, problem, node, explored, frontier, deterministic):
            return [(self.child_node(problem, action, explored, node, frontier))
                for action in problem.actions(self.robot_node, self.room, node, deterministic)]

        def child_node(self, problem, action, explored, node, frontier):
            next_state = problem.result(node, action, explored, frontier, problem)


            if next_state is None:
                stato = ("'" + self.robot_node + "'", {self.room})
                return None, None


            next_rooms = [row[:] for row in self.rooms]  # Crea una copia della matrice per il child node
            next_frontier = frontier.copy()  # Copia la frontiera locale
            next_explored = explored.copy()  # Copia gli stati esplorati locali

       
            next_node = Node(next_state[0], next_state[1], next_rooms, self, action, problem.path_cost(self.path_cost, self, action, next_state), next_frontier, next_explored)

            return next_node, next_state

        def path(self):
            node, path_back = self, []
            while node:
                path_back.append(node)
                node = node.parent
            return list(reversed(path_back))

        def __hash__(self):
            return hash((self.robot_node, self.room))

