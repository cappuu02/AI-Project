def remove_grid(image):
    edges = cv2.Canny(image, 50, 700, apertureSize=3)
    kernel = np.ones((5, 5), np.uint8)
    edges = cv2.morphologyEx(edges, cv2.MORPH_CLOSE, kernel)
    lines = cv2.HoughLinesP(edges, 0.1, np.pi / 180, threshold=100, minLineLength=150, maxLineGap=20)

    if lines is not None:
        for line in lines:
            x1, y1, x2, y2 = line[0]
            cv2.line(image, (x1, y1), (x2, y2), (255, 255, 255), 10)

    return image

# Funzione per mostrare l'immagine
def show_image(image):
    plt.imshow(image, cmap='gray')
    plt.axis('off')
    plt.show()

# Widget per caricare e visualizzare l'immagine
def load_and_display_image(image_name):
    image = cv2.imread(image_name)
    image_without_grid = remove_grid(image)
    show_image(image_without_grid)
    return image_without_grid

def stampa_matrice(rooms):
    rows, cols = len(rooms), len(rooms[0])
    # Calcola la lunghezza massima delle coordinate delle colonne
    max_col_width = len(str(cols - 1))

    # Stampa le coordinate superiori della matrice
    print(" " * (max_col_width + 2), end=" ")
    for col in range(cols):
        print(str(col).rjust(max_col_width), end=" ")
    print()
    print("-" * (max_col_width + 4 + cols * 2))

    # Stampa la matrice
    for row in range(rows):
        print(str(row).rjust(max_col_width), "|", end=" ")
        for col in range(cols):
            print(rooms[row][col], end=" ")
        print()
    

