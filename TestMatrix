#Rimuove la griglia dalle immagini
def remove_grid(image):                                                                                        
    edges = cv2.Canny(image, 50, 700, apertureSize=3) #Funzione che implementa l'algoritmo rilevamento bordi di Canny, 50 valore minimo soglia bassa gradiente, 700 valore massimo soglia alta gradiente, 3 è la dimensione del kernel del filtro di Sobel utilizzato per il rilevamento dei gradienti
    kernel = np.ones((5, 5), np.uint8) # Definisce un kernel per l'operazione di chiusura morfologica, un kernel è una matrice che definisce come i pixel dell'immagine di input sono combinati per ottenere output
    edges = cv2.morphologyEx(edges, cv2.MORPH_CLOSE, kernel) #Applica una chiusura morfologica all'immagine dei bordi, questo aiuta a collegare le linee interrotte e a eliminare i dettagli indesiderati
    lines = cv2.HoughLinesP(edges, 0.1, np.pi / 180, threshold=100, minLineLength=150, maxLineGap=20) # Applica la trasformata di Hough per individuare le linee nell'immagine dei bordi, 0.1 è rho risoluzione in pixel dell'accumulatore della trasformata di Hough, np.pi/ 180 risoluzione angolare dell'accumulatore della trasformata di Hough in radianti, threshold: Soglia per la rilevazione delle linee. 100 threshold solo le linee con un numero di voti maggiori o uguali a questa soglia verranno considerate, 150 lunghezza minima della linea da considerare, 20 massima distanza tra i punti per considerarli appartenenti alla stessa linea.

    if lines is not None:
        for line in lines:
            x1, y1, x2, y2 = line[0] # Estrae i punti di inizio e fine della linea
            cv2.line(image, (x1, y1), (x2, y2), (255, 255, 255), 10) # Disegna una linea bianca sopra la linea originale nell'immagine di spessore 10

    return image

# Funzione per mostrare l'immagine
def show_image(image):
    plt.imshow(image, cmap='gray') #Stampa l'immagine in scala di grigi
    plt.axis('off')
    plt.show()

# Funzione per caricare e visualizzare l'immagine
def load_and_display_image(image_name):
    image = cv2.imread(image_name) #Legge l'immagine
    image_without_grid = remove_grid(image) 
    show_image(image_without_grid) #Chiama la funzione per stampare l'immagine
    return image_without_grid

# Funzione per stampare una matrice di stanze con coordinate (row,col)
def stampa_matrice(rooms):
    rows, cols = len(rooms), len(rooms[0]) # Ottiene il numero di righe e colonne della matrice
    max_col_width = len(str(cols - 1)) # Calcola la lunghezza massima delle coordinate delle colonne

    # Stampa le coordinate superiori della matrice
    print(" " * (max_col_width + 2), end=" ") # Stampa le coordinate superiori della matrice
    for col in range(cols): # Stampa le coordinate delle colonne allineate a destra
        print(str(col).rjust(max_col_width), end=" ")
    print()
    print("-" * (max_col_width + 4 + cols * 2)) # Stampa la riga di separazione

    # Stampa la matrice
    for row in range(rows):
        print(str(row).rjust(max_col_width), "|", end=" ") # Stampa la coordinata della riga allineata a destra
        for col in range(cols): 
            print(rooms[row][col], end=" ") # Stampa il valore della cella della matrice
        print()


