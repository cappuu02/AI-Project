#Funzione che prende in input immagine di una matrice e rimuove la griglia
def remove_grid(image):
    edges = cv2.Canny(image, 20, 200, apertureSize=3) #Rileva Bordi Immagine
    kernel = np.ones((5, 5), np.uint8) #kernel di dimensioni 5x5 pieno
    edges = cv2.morphologyEx(edges, cv2.MORPH_CLOSE, kernel)     #applicata la chiusura morfologica sull'immagine dei bordi
    lines = cv2.HoughLinesP(edges, 0.1, np.pi / 180, threshold=100, minLineLength=150, maxLineGap=20) #utilizzata la trasformata di Hough probabilistica per individuare le linee nell'immagine dei bordi.

    if lines is not None: #condizione (linee rilevate)
        for line in lines: #ciclo itera attraverso ogni linea individuata nell'immagine
            x1, y1, x2, y2 = line[0] #Estrae le coordinate dei punti di inizio e fine della linea.
            cv2.line(image, (x1, y1), (x2, y2), (255, 255, 255), 10) #disegna una linea bianca sull'immagine image dai punti (x1, y1) a (x2, y2)
    return image


# funzione per caricare e visualizzare immagine
def load_and_display_image(image_name):
    image = cv2.imread(image_name) #legge immagine
    image_without_grid = remove_grid(image) #rimuovi griglia
    return image_without_grid #ritorniamo l'immagine senza griglia

