import cv2
from keras.models import load_model
import numpy as np

# Carica l'immagine
path = 'matrice.png'
image = cv2.imread(path, cv2.IMREAD_GRAYSCALE)  # Carica l'immagine in scala di grigi

# Ridimensiona l'immagine (se necessario)
resized_image = cv2.resize(image, (0, 0), fx=0.5, fy=0.5)  # Ridimensiona l'immagine al 50% della dimensione originale

# Applica il filtro Gaussiano per ridurre il rumore
blurred_image = cv2.GaussianBlur(resized_image, (5, 5), 0)

# Binarizzazione dell'immagine utilizzando la sogliatura di Otsu
_, binary_image = cv2.threshold(blurred_image, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)

# Inverti i colori dell'immagine binaria
binary_image = cv2.bitwise_not(binary_image)

# Trova i contorni nell'immagine binaria
contours, _ = cv2.findContours(binary_image, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

# Inizializza una lista per contenere le lettere predette
predicted_letters = []

# Trova estra e visualizza la ROI per ogni contorno trovato
for contour in contours:
    # Calcola l'area del contorno
    contour_area = cv2.contourArea(contour)

    # Imposta un limite minimo sull'area dei contorni da considerare come ROI
    min_contour_area = 80 # Modifica questo valore secondo necessità

    # Se l'area del contorno supera il limite minimo
    if contour_area > min_contour_area:
        # Trova i rettangoli di delimitazione della ROI
        x, y, w, h = cv2.boundingRect(contour)

        # Estrai la ROI
        roi = binary_image[y:y+h, x:x+w]

        # Ridimensiona la ROI a 28x28 pixel
        roi_resized = cv2.resize(roi, (28, 28))

        # Normalizza l'immagine
        image_normalized = roi_resized / 255.0

        # Aggiungi una dimensione per il batch
        input_data = image_normalized.reshape(1, 28, 28, 1)

        # Carica il modello OCR preaddestrato
        model = load_model('venv/MioModello')  # Assicurati di specificare il percorso corretto del modello salvato

        # Esegui il riconoscimento del testo nell'immagine utilizzando il modello OCR
        predictions = model.predict(input_data)

        # Ottieni il valore predetto
        predicted_value = np.argmax(predictions)

        # Dizionario per mappare le lettere ai valori desiderati
        letter_mapping = {'S': 19, 'C': 3, 'X': 24, 'V': 22, 'D': 4, 'F': 6}

        # Traduci l'indice nella lettera corrispondente
        predicted_letter = ''
        for letter, value in letter_mapping.items():
            if value == predicted_value:
                predicted_letter = letter
                break

        # Aggiungi la lettera predetta alla lista delle lettere predette
        predicted_letters.append((predicted_letter, x, y))

# Ordina le lettere per coordinata y (ordine verticale)
predicted_letters.sort(key=lambda x: x[2])

# Trova le righe di lettere
row_letters = []
current_row = []
prev_y = None
for letter_info in predicted_letters:
    _, _, y = letter_info
    if prev_y is None or abs(y - prev_y) < 30:  # Definisci una soglia per la distanza massima tra le lettere per considerarle nella stessa riga
        current_row.append(letter_info)
    else:
        row_letters.append(sorted(current_row, key=lambda x: x[1]))  # Ordina le lettere per coordinata x (ordine orizzontale)
        current_row = [letter_info]
    prev_y = y
row_letters.append(sorted(current_row, key=lambda x: x[1]))  # Aggiungi l'ultima riga

# Converte le lettere ordinate in una matrice di lettere
predicted_matrix = [[letter_info[0] for letter_info in row] for row in row_letters]

print("Matrice delle lettere predette (ordine verticale):")
for row in predicted_matrix:
    print(row)








