class Node:
    def __init__(self, robot_node, rooms, parent=None, action=None, path_cost=0):
        self.robot_node = robot_node
        self.rooms = rooms
        self.parent = parent
        self.action = action
        self.path_cost = path_cost

    def __repr__(self):
        return f"<Node {self.robot_node}, Action: {self.action}>"

    def generate_all_nodes(self, problem):
        all_nodes = []
        frontier = deque([self])

        while frontier:
            node = frontier.popleft()
            all_nodes.append(node)
            frontier.extend(node.expand(problem))

        return all_nodes

    def expand(self, problem):

           return [(self.child_node(problem, action).robot_node, self.child_node(problem, action).rooms)
        for action in problem.actions(self.robot_node)]



    def child_node(self, problem, action):
      
        next_state = problem.result(self, action)
        print(next_state)
        next_node = Node(next_state[0], next_state[1], self, action,
                 problem.path_cost(self.path_cost, self, action, next_state))
        print(next_node)
        return next_node

    def solution(self):
        return [node.action for node in self.path()[1:]]

    def path(self):
        node, path_back = self, []
        while node:
            path_back.append(node)
            node = node.parent
        return list(reversed(path_back))

    def apply_action(self, action):
        new_node = Node(self.robot_node, [row[:] for row in self.rooms])
        robot_row, robot_col = self.robot_node

        if action == "clean":
            new_node.rooms[robot_row][robot_col] = 'C'
        elif action == "move_up":
            new_node.robot_node = (robot_row - 1, robot_col)
        elif action == "move_down":
            new_node.robot_node = (robot_row + 1, robot_col)
        elif action == "move_left":
            new_node.robot_node = (robot_row, robot_col - 1)
        elif action == "move_right":
            new_node.robot_node = (robot_row, robot_col + 1)

        return new_node

    def __hash__(self):
        return hash(self.state)



def breadth_search_first(problem):
    initial_state = find_initial_position(problem.rooms)
    print(initial_state)
    initial_node = Node(initial_state, problem.rooms)  
    print(initial_node)
    if problem.goal_test(initial_state):
        return initial_node

    frontier = deque([initial_node])
    print(frontier)
    explored = set()


    while frontier:
        node = frontier.popleft()
        print("Current Node:", node)  # Stampa il nodo corrente
        explored.add(node.robot_node)  
        print(explored)
        for child in node.expand(problem):  
            print("-")
            print(child)
            print(child.robot_node)
            if child.robot_node not in explored and child not in frontier:
                if problem.goal_test(child.robot_node):  
                    print("Last Expanded: ", node)
                    print("# explored BFS: ", len(explored))
                    return child
                frontier.append(child)
    return None


def find_initial_position(rooms):
    for row_idx, row in enumerate(rooms):
        for col_idx, cell in enumerate(row):
            if cell == "S":
                position = (row_idx, col_idx)  # Aggiungi 1 agli indici per ottenere le coordinate basate su 1
                return ("S", position)  # Ritorna una tupla con il simbolo e le coordinate
        
    return None

def find_letter_position(rooms, row, col):
    return rooms[row][col]

def update_letter_position(rooms, row, col, new_letter):
    rooms[row][col] = new_letter


