                    possible_actions.append("move_up")

            if robot_row < len(rooms) - 1:
                lettera = find_letter_position(rooms, room[0] + 1, room[1])
                if(lettera) != self.deny:
                    possible_actions.append("move_down")

            if robot_col > 0:
                lettera = find_letter_position(rooms, room[0], room[1] - 1)
                if lettera != self.deny:
                    possible_actions.append("move_left")

            if robot_col < len(rooms) - 1:
                lettera = find_letter_position(rooms, room[0], room[1] + 1)
                if lettera != self.deny:
                    possible_actions.append("move_right")

            return possible_actions

