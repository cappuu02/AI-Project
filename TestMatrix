    class Node:
        def __init__(self, robot_node, room, rooms, parent = None, action = None, path_cost = 0, frontier = deque(), explored = set()):
            self.robot_node = robot_node
            self.room = room
            self.rooms = rooms
            self.parent = parent
            self.action = action
            self.path_cost = path_cost
            self.frontier = frontier or deque()
            self.explored = explored


        def __repr__(self):
            return f"<Node ('{self.robot_node}', {self.room}, {self.rooms})>"


        def expand(self, problem, node, deterministic, GreedyAlt):
            return [(self.child_node(problem, node, action))
                for action in problem.actions(self.robot_node, self.room, node, deterministic, GreedyAlt)]


        def child_node(self, problem, node, action):
            next_state = problem.result(node, action, problem)

            if next_state is None:
                stato = ("'" + self.robot_node + "'", {self.room})
                return None, None

            next_rooms = [row[:] for row in self.rooms]  # Crea una copia della matrice per il child node
            next_frontier = node.frontier.copy()  # Copia la frontiera locale
            next_explored = node.explored.copy()  # Copia gli stati esplorati locali

            next_node = Node(next_state[0], next_state[1], next_rooms, self, action, problem.path_cost(self.path_cost, self, action, next_state), next_frontier, next_explored)

            return next_node, next_state


        def path(self):
            node, path_back = self, []

            while node:
                path_back.append(node)
                node = node.parent

            return list(reversed(path_back))



    class NodeGreedy:
        def __init__(self, robot_node, room, rooms, f, g, parent = None, action = None, path_cost = 0, frontier = PriorityQueue(), explored = set()):
            self.robot_node = robot_node
            self.room = room
            self.rooms = rooms
            self.f = f
            self.g = g
            self.parent = parent
            self.action = action
            self.path_cost = path_cost
            self.frontier = frontier or PriorityQueue()
            self.explored = explored or set()


        def __lt__(self, other):
            return self.f < other.f


        def __repr__(self):
            return f"<Node ('{self.robot_node}', {self.room}, {self.rooms})>"


        def expand(self, problem, node, deterministic, GreedyAlt):
            return [(self.child_node(problem, action, node))
                for action in problem.actions(self.robot_node, self.room, node, deterministic, GreedyAlt)]


        def child_node(self, problem, action, node):
            next_state = problem.result(node, action, problem)
            
            if next_state is None:
                stato = ("'" + self.robot_node + "'", {self.room})
                return None, None

            next_room = next_state[1]
            next_rooms = [row[:] for row in self.rooms]  # Crea una copia della matrice per il child node
            next_frontier = copy.deepcopy(node.frontier)  # Copia la frontiera locale
            next_explored = node.explored.copy()  # Copia gli stati esplorati locali
            next_g = problem.h_update(next_room, node)
            next_f = problem.h_extract(next_room, next_g)                    

            next_node = NodeGreedy(next_state[0], next_state[1], next_rooms, next_f, next_g, self, action, problem.path_cost(self.path_cost, self, action, next_state), next_frontier, next_explored)

            return next_node, next_state


        def path(self):
            node, path_back = self, []
            
            while node:
                path_back.append(node)
                node = node.parent

            return list(reversed(path_back))



