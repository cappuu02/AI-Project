class SmartVacuum(Problem):
    def __init__(self, initial):
        self.initial = "S"
        self.goal = "F"
        self.deny = "X"
        self.clean = "C"
        self.dirty = "D"
        self.Vdirty = "V"
        self.graph = None
        self.rooms = rooms

    def actions(self, node, room):


      #robot_node = lettera e rooms = coordinate x/y
      possible_actions = []
      robot_row, robot_col = room


      if node in [self.dirty]:
          possible_actions.append("clean")

      if node in [self.Vdirty]:
          possible_actions.append("Vclean")

      #Verifichiamo se l'azione UP è possibile
      if robot_row > 0:
          lettera = find_letter_position(rooms, room[0] - 1, room[1])#mi salvo la lettera sopra
          if lettera != self.deny:#se la lettera è doversa dalla X di deny allora posso eseguire l'azione
              possible_actions.append("move_up")#quindi, la aggiungo nella lista

      if robot_row < len(rooms) - 1:
          lettera = find_letter_position(rooms, room[0] + 1, room[1])
          if(lettera) != self.deny:
              possible_actions.append("move_down")

      if robot_col > 0:
          lettera = find_letter_position(rooms, room[0], room[1] - 1)
          if lettera != self.deny:
              possible_actions.append("move_left")

      if robot_col < len(rooms) - 1:
          lettera = find_letter_position(rooms, room[0], room[1] + 1)
          if lettera != self.deny:
              possible_actions.append("move_right")


      return possible_actions

    def result(self, node, action):
        #salva la lettera
        room = node.room


        if action == "clean":
            update_letter_position(rooms, room[0], room[1], "C")
            print("")
            print("Pulisco la stanza",room,"con costo 1 (D->C):")

            stampa_matrice(rooms)
            print("")
            return None  # Indica che l'azione di pulizia è stata eseguita

        if action == "Vclean":
            update_letter_position(rooms, room[0], room[1], "C")
            print("")
            print("Pulisco la stanza",room,"con costo 3 (V->C):")

            stampa_matrice(rooms)
            print("")
            return None  # Indica che l'azione di pulizia è stata eseguita


        if action == "move_up":
            lettera = find_letter_position(rooms, room[0] - 1, room[1])
            robot_node = (lettera, (room[0] - 1, room[1]))#state[1][1] = il primo [1] mi identifica la seconda tupla mentre il secondo [0] mi identifica il primo elemento della seconda tupla
        if action == "move_down":
            lettera = find_letter_position(rooms, room[0] + 1, room[1])
            robot_node = (lettera, (room[0] + 1, room[1]))
        if action == "move_left":
            lettera = find_letter_position(rooms, room[0], room[1] - 1)
            robot_node = (lettera, (room[0], room[1] - 1))
        if action == "move_right":
            lettera = find_letter_position(rooms, room[0], room[1] + 1)
            robot_node = (lettera, (room[0], room[1] + 1))


        #return del nodo figlio che abbiamo scoperto dal padre

        return robot_node

    def goal_test(self, state):
        #robot_info = lettera, rooms = coordinate x/y
        robot_info, room = state
        if robot_info == self.goal:
            for row in range(len(rooms)):
                for col in range(len(rooms)):
                    lettera = find_letter_position(rooms, row, col)
                    if lettera in [self.dirty, self.Vdirty]:

                        print("!!!!E' stata esplorata la destinazione finale(F) ma ci sono ancora stanze sporche da pulire!!!!")
                        return False
            print("")
            print("Tutte le stanze sono pulite(C), ecco la matrice finale:")
            stampa_matrice(rooms)
            print("")
            return True
        return False


class Node:
    def __init__(self, robot_node, room, parent = None, action = None, path_cost = 0):
        self.robot_node = robot_node
        self.room = room
        self.parent = parent
        self.action = action
        self.path_cost = path_cost


    def __repr__(self):
      return f"<Node ('{self.robot_node}', {self.room})>"

    def expand(self, problem):
        return [(self.child_node(problem, action))#uno per la posizione uno per il nodo effettivo
          for action in problem.actions(self.robot_node, self.room)]#mi dice quali azioni posso fare dal nodo attuale
          #for viene eseguito prima del return perchè result lavora con action



    def child_node(self, problem, action):
        next_state = problem.result(self, action)#in next state salviamo il nodo figlio che ci viene dato dalla funzione result

        if next_state is None:
            stato = ("'" + self.robot_node + "'", {self.room})
            return self, stato  # Se next_state è None, restituisci None sia per il nodo che per lo stato

        next_node = Node(next_state[0], next_state[1], self, action, problem.path_cost(self.path_cost, self, action, next_state))
        #next_node = Node(next_state[0], next_state[1], self, action, problem.path_cost(self.path_cost, self, action, next_state))#creazione nodo figlio che abbiamo scoperto


        return next_node, next_state

    def path(self):
        node, path_back = self, []
        while node:
            path_back.append(node)
            node = node.parent
        return list(reversed(path_back))


    def __hash__(self):
        return hash((self.robot_node, self.room))



