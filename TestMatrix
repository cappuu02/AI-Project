class SmartVacuum(Problem):
    def __init__(self, initial):
        self.initial = "S"
        self.goal = "F"
        self.deny = "X"
        self.clean = "C"
        self.dirty = "D"
        self.Vdirty = "V"
        self.graph = None
        self.rooms = rooms

    def actions(self, state):
      robot_node, rooms = state
      possible_actions = []

      robot_row, robot_col = robot_node

      if rooms[robot_row][robot_col] in [self.dirty, self.Vdirty]:
          possible_actions.append("clean")

      if robot_row > 0 and rooms[robot_row - 1][robot_col] != self.deny:
          possible_actions.append("move_up")
      if robot_row < len(rooms) - 1 and rooms[robot_row + 1][robot_col] != self.deny:
          possible_actions.append("move_down")
      if robot_col > 0 and rooms[robot_row][robot_col - 1] != self.deny:
          possible_actions.append("move_left")
      if robot_col < len(rooms[0]) - 1 and rooms[robot_row][robot_col + 1] != self.deny:
          possible_actions.append("move_right")

      return possible_actions



    def result(self, state, action):
        robot_node, rooms = state
        robot_row, robot_col = robot_node

        if action == "clean":
            rooms[robot_row][robot_col] = self.clean

        if action == "move_up":
            robot_node = (robot_row - 1, robot_col)
        elif action == "move_down":
            robot_node = (robot_row + 1, robot_col)
        elif action == "move_left":
            robot_node = (robot_row, robot_col - 1)
        elif action == "move_right":
            robot_node = (robot_row, robot_col + 1)

        return robot_node, rooms

    def goal_test(self, state):
      robot_info, rooms = state
      robot_letter, (robot_row, robot_col) = robot_info

