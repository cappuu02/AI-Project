            # Apri l'immagine
            image = Image.open(self.image_path)

            # Ottieni le dimensioni massime consentite per l'immagine
            max_width = self.root.winfo_width() - 500  # Larghezza massima consentita
            max_height = self.root.winfo_height() - 500  # Altezza massima consentita

            # Verifica se le dimensioni dell'immagine superano i limiti consentiti
            if image.width > max_width or image.height > max_height:
                # Calcola i rapporti di ridimensionamento per mantenere l'aspect ratio
                width_ratio = max_width / image.width
                height_ratio = max_height / image.height

                # Se l'immagine è più ampia del consentito, ridimensiona rispettando l'aspect ratio
                if width_ratio < height_ratio:
                    new_width = max_width
                    new_height = int(image.height * (max_width / image.width))
                # Altrimenti, se l'immagine è più alta del consentito, ridimensiona rispettando l'aspect ratio
                else:
                    new_height = max_height
                    new_width = int(image.width * (max_height / image.height))

                # Ridimensiona l'immagine
                image = image.resize((new_width, new_height))

            # Carica l'immagine nell'interfaccia utente
            photo = ImageTk.PhotoImage(image)
            self.image_label.config(image=photo)
            self.image_label.image = photo  # Aggiornamento della variabile di classe photo per evitare la perdita

            # Process image
