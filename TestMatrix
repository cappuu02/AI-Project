        # Converti gli array numpy in oggetti PIL.Image
        image_sequence = [Image.fromarray(img) for img in T_images]

        matrice_iniziale = "\n".join(
            "  ".join(str(cell) + "\u2006" if cell == "X" else str(cell) for cell in row) for row in rooms)


        var_da_stampare = []

        if (nodo_stampare == None and var_deterministic == None):
            self.output_text.config(state=tk.NORMAL)
            self.output_text.delete("1.0", tk.END)
            var_da_stampare.append("Impossibile trovare soluzione, matrice invalida!")
            var_da_stampare.append("\nMatrice letta: ")
            var_da_stampare.append("\n" + str(matrice_iniziale) + "")
            var_da_stampare.append("Tempo di lettura: " + str(round(time_ocr, 3)) + "s")
            testo_formattato = "\n".join(var_da_stampare)
            self.display_image_sequence(image_sequence)
            self.output_text.insert(tk.END, testo_formattato)
            self.output_text.config(state=tk.DISABLED)  # Disabilita il widget di output per impedire la modifica
            return None

        if (nodo_stampare == None and var_deterministic != None):
            self.output_text.config(state=tk.NORMAL)
            self.output_text.delete("1.0", tk.END)
            var_da_stampare.append("Impossibile raggiungere la stanza finale(F) e/o pulire tutte le stanze(D,V)!")
            var_da_stampare.append("\nMatrice letta: ")
            var_da_stampare.append("\n" + str(matrice_iniziale) + "")
            var_da_stampare.append("Tempo di lettura: " + str(round(time_ocr, 3)) + "s")
            testo_formattato = "\n".join(var_da_stampare)
            self.display_image_sequence(image_sequence)
            self.output_text.insert(tk.END, testo_formattato)
            self.output_text.config(state=tk.DISABLED)  # Disabilita il widget di output per impedire la modifica
            return None



        var_da_stampare.append("Matrice letta: ")
        var_da_stampare.append("\n" + str(matrice_iniziale) + "")
        var_da_stampare.append("Tempo di lettura: " + str(round(time_ocr, 3)) + "s")

        var_da_stampare.append("\n\nOutput Algoritmo: ")
        var_da_stampare.append("Tempo di esecuzione: " + str(round(time_alg,7)) + "s")
        matrice_finale = "\n".join(
            "  ".join(str(cell) + "\u2006" if cell == "X" else str(cell) for cell in row) for row in nodo_stampare.rooms)

        matrice_finale_euristica = "\n".join(
                            " ".join(str(cell).rjust(3) if len(str(cell)) == 2 else str(cell).rjust(3) + "\u2009" if cell != math.inf else "X".rjust(3) + "\u2009" for cell in row) for row in nodo_stampare.g)

        combined_matrices = []
        for state_row, heuristic_row in zip(matrice_finale.split('\n'), matrice_finale_euristica.split('\n')):
            combined_matrices.append(state_row + "     " + heuristic_row)

        var_da_stampare.append("\nMatrice finale: ")
        var_da_stampare.append("\n". join(combined_matrices))
        var_da_stampare.append("\nNodo Finale: " + str(nodo_stampare.robot_node) + str(nodo_stampare.room))
        var_da_stampare.append("Costo Distanza: " + str(nodo_stampare.path_cost))
        var_da_stampare.append("Costo Pulizia Dirty(1): " + str(var_dirty))
        var_da_stampare.append("Costo Pulizia Vdirty(3): " + str(var_Vdirty))
        var_da_stampare.append("Costo Totale: " + str(nodo_stampare.path_cost + var_dirty + var_Vdirty))
        var_da_stampare.append("Percorso fatto: ")
        for node in nodo_stampare.path():
            var_da_stampare.append(str(node.room) + "Azioni verso la stanza: " + str(node.action))
        var_da_stampare.append("")

        var_da_stampare.append("\nEsecuzione Algoritmo GreedyAlt: ")
        for i, node in enumerate(nodo_stampare.path()):
            # Formatta la matrice dello stato corrente
            state_matrix = "\n".join(
            "  ".join(str(cell) + "\u2006" if cell == "X" else str(cell) for cell in row) for row in node.rooms)

            heuristic_formatted = "\n".join(
                " ".join(str(cell).rjust(3) if len(str(cell)) == 2 else str(cell).rjust(
                    3) + "\u2009" if cell != math.inf else "X".rjust(3) + "\u2009" for cell in row) for row in
                node.g)

            # Unisci la matrice dello stato corrente e quella dell'euristica
            combined_matrices = []
            for state_row, heuristic_row in zip(state_matrix.split('\n'), heuristic_formatted.split('\n')):
                combined_matrices.append(state_row + "     " + heuristic_row)

            # Aggiungi un'intestazione sopra ogni matrice
            var_da_stampare.append(f"\nPasso {i + 1}:")

            var_da_stampare.append("\n".join(combined_matrices))
            var_da_stampare.append("")  # Aggiungi una riga vuota tra le righe della matrice
            var_da_stampare.append("Nodo Corrente: "+ str(node.robot_node) + str( node.room))
            var_da_stampare.append("Azione verso Nodo Corrente: " + str(node.action))
            var_da_stampare.append("Nodo Parent: " + str(node.parent))
            frontier_contents = [item for priority, item in node.frontierpre.heap]
            frontier_string = "[" + ", ".join(str(item) for item in frontier_contents) + "]"
            var_da_stampare.append("\nFrontiera Corrente: " + frontier_string)  # Aggiungere la rappresentazione della frontiera alla lista di output
            var_da_stampare.append("\nEsplorati Corrente: " + str(node.explored) + "\n")


        testo_formattato = "\n".join(var_da_stampare)

        self.output_text.config(state=tk.NORMAL)  # Abilita il widget di output
        self.output_text.delete("1.0", tk.END)
        self.display_image_sequence(image_sequence)
        self.output_text.insert(tk.END, testo_formattato)
        self.output_text.config(state=tk.DISABLED)  # Abilita il widget di output
        return

