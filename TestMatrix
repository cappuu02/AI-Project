    #Definizione Classe Node (node into a search three)
    class Node:
        def __init__(self, robot_node, room, rooms, parent=None, action=None, path_cost=0, frontier=deque(), frontierpre = deque(),explored=set(), countloop = 0):
            self.robot_node = robot_node
            self.room = room
            self.rooms = rooms
            self.parent = parent
            self.action = action
            self.path_cost = path_cost
            self.frontier = frontier or deque()
            self.explored = explored
            self.frontierpre = frontierpre or deque()
            self.countloop = countloop

        #funzione che ritorna lo stato del nodo
        def __repr__(self):
            return f"<Node ('{self.robot_node}', {self.room})>"

        #metodo che elenca tutti i nodi vicini (raggiungibili in un solo passaggio) del nodo corrente.
        #Deterministic: Booleano per deterministica o meno.
        #GreedyAlt: Booleano che indica se si sta usando un approccio greedy
        def expand(self, problem, node, deterministic, GreedyAlt):
            return [(self.child_node(problem, node, action))
                    for action in problem.actions(self.robot_node, self.room, node, deterministic, GreedyAlt)]
        
        #restituisce il neighbour immediato che può essere raggiunto con quell'azione
        def child_node(self, problem, node, action):
            next_state = problem.result(node, action, problem)

            if next_state is None:
                stato = ("'" + self.robot_node + "'", {self.room})
                return None, None

            next_rooms = [row[:] for row in self.rooms]  # Crea una copia della matrice per il child node
            next_frontierpre = node.frontierpre.copy()
            next_frontier = node.frontier.copy()  # Copia la frontiera locale
            next_explored = node.explored.copy()  # Copia gli stati esplorati locali

            next_node = Node(next_state[0], next_state[1], next_rooms, self, action,
                             problem.path_cost(self.path_cost, self, action, next_state), next_frontier, next_frontierpre, next_explored)

            return next_node, next_state
        
        #restituisce un elenco di tutti i nodi che si trovano nel percorso dalla radice a questo nodo.
        def path(self):
            node, path_back = self, []
            while node:
                path_back.append(node)
                node = node.parent
            return list(reversed(path_back))

    #Classe per funzione Greedy (Euristiche)
    class NodeGreedy:
        def __init__(self, robot_node, room, rooms, f, g, parent=None, action=None, path_cost=0,
                     frontier=None, frontierpre=None, explored=None, countloop = 0):
            self.robot_node = robot_node
            self.room = room
            self.rooms = rooms
            self.f = f
            self.g = g
            self.parent = parent
            self.action = action
            self.path_cost = path_cost
            self.frontier = frontier if frontier is not None else PriorityQueue()
            self.explored = explored if explored is not None else set()
            self.frontierpre = frontierpre if frontierpre is not None else PriorityQueue()
            self.countloop = countloop

        # Ritorna true se l'oggetto corrente ha una costo f minore dell'oggetto other.
        # La funzione < deve essere usata per tenere traccia della lista dei nodi con costo minimo
        # in una coda di priorità (PriorityQueue)
        def __lt__(self, other):
            return self.f < other.f
        
        # Funzione Ritorna una stringa con la rappresentazione dell'oggetto NodeGreedy.
        def __repr__(self):
            """Ritorna una stringa con la rappresentazione dell'oggetto."""
            return "<Node ({}, {})>".format(repr(self.robot_node), repr(self.room))


        # Restituisce una lista di nodi figli generati dal nodo corrente.
        def expand(self, problem, node, deterministic, GreedyAlt):
            #Restituisce una lista di nodi figli generati dal nodo corrente.
            return [(
                self.child_node(problem, action, node))  # Crea un nodo figlio per ogni azione
                    for action in problem.actions(self.robot_node, self.room, node, deterministic, GreedyAlt)]  # Genera azioni per il nodo corrente

        
        #funzione che genera un nodo figlio dal parent grazie ad un'azione
        def child_node(self, problem, action, node):
            next_state = problem.result(node, action, problem)  # Genera lo stato successivo

            if next_state is None:  # Se l'azione genera uno stato inesplorato restituisce un nodo figlio e lo stato generato
                return None, None

            next_room = next_state[1]  # Stato generato
            next_rooms = [row[:] for row in self.rooms]  # Crea una copia della matrice per il child node
            next_frontier = copy_priority_queue(node.frontier)  # Copia la frontiera locale
            next_frontierpre = copy_priority_queue(node.frontierpre)

            next_explored = node.explored.copy()  # Copia gli stati esplorati locali
            next_g = problem.h_update(next_room, node)  # Calcola la nuova h(nodo)
            next_f = problem.h_extract(next_room, next_g)  # Calcola il nuovo f(nodo) = g(nodo) + h(nodo)
            next_node = NodeGreedy(next_state[0], next_state[1], next_rooms, next_f, next_g, self, action,
                                   problem.path_cost(self.path_cost, self, action, next_state), next_frontier, next_frontierpre,
                                   next_explored)

            return next_node, next_state # Restituisce un nodo figlio generato dal nodo corrente passando l'azione 'action'

        #funzione che ritorna la lista del path dal nodo corrente al root node.
        def path(self):
            node, path_back = self, []

            while node:
                path_back.append(node)
                node = node.parent

            return list(reversed(path_back))

    
    
    
