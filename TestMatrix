            self.deny = "X"
            self.clean = "C"
            self.dirty = "D"
            self.Vdirty = "V"
            self.graph = None

        def build_graph(self, rooms):
          # Ottieni le dimensioni della matrice
          rows, cols = len(rooms), len(rooms[0])
         # Crea un grafo non diretto vuoto
          G = nx.Graph()

          # Aggiungi nodi e archi al grafo in base alle connessioni tra le stanze
          for row in range(rows):
              for col in range(cols):
                 if rooms[row][col] != self.deny:
                      G.add_node((row, col))  # Aggiungi il nodo corrispondente alla stanza

                      # Aggiungi archi per connessioni valide a destra e in basso
                      if col < cols - 1 and rooms[row][col + 1] != self.deny:
                          G.add_edge((row, col), (row, col + 1))

                      if row < rows - 1 and rooms[row + 1][col] != self.deny:
                         G.add_edge((row, col), (row + 1, col))

          return G


        def actions(self, state):
            robot_node, rooms = state
            possible_actions = []

            # Definisci azioni basate sulla posizione del robot e sullo stato delle stanze
            # Ad esempio, se la stanza in cui si trova il robot è sporca, aggiungi 'clean'
            # Se il robot può muoversi in una certa direzione, aggiungi 'move'
            robot_row, robot_col = robot_node

            if rooms[robot_row][robot_col] in [self.dirty, self.Vdirty]:
                possible_actions.append("clean")

            # Aggiungi azioni per il movimento in direzioni valide
            neighbors = list(self.graph.neighbors(robot_node))
            for neighbor_node in neighbors:
              neighbor_row, neighbor_col = neighbor_node
              if rooms[neighbor_row][neighbor_col] != self.deny:
                  # Determina la direzione del movimento rispetto alla posizione attuale del robot
                  if neighbor_row < robot_row:
                      possible_actions.append("move_up")
                  elif neighbor_row > robot_row:
                      possible_actions.append("move_down")
                  elif neighbor_col < robot_col:
                      possible_actions.append("move_left")
                  elif neighbor_col > robot_col:
                      possible_actions.append("move_right")

            return possible_actions


        def result(self, state, action):
            robot_node, rooms = state
            robot_row, robot_col = robot_node

            if action == "clean":
                rooms[robot_row][robot_col] = self.clean

            if action == "move_up":
                robot_node = (robot_row - 1, robot_col)
            elif action == "move_down":
                robot_node = (robot_row + 1, robot_col)
            elif action == "move_left":
                robot_node = (robot_row, robot_col - 1)
            elif action == "move_right":
                robot_node = (robot_row, robot_col + 1)

            return robot_node, rooms




        def goal_test(self, state):
