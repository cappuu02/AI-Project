    def DfsAlt_greedy(problem, g):
        start_time_alg = time.time()
        max_count = len(rooms) * len(rooms) * 20
        count = 0

        initial_state = find_initial_position(rooms)
        state, room = initial_state

        f = problem.h_extract(room, g)

        node = NodeGreedy(state, room, rooms, f, g)
        for priority, item in node.frontier.heap:
            print("PRE", item)
        node.frontier.append(node)
        for priority, item in node.frontier.heap:
            print("post", item)

        dirty_count, Vdirty_count = count_dirty_rooms(rooms)

        while node.frontier and count < max_count:
            count += 1
            deterministic = True
            node.frontierpre = copy_priority_queue(node.frontier)

            for priority, item in node.frontier.heap:
                print("PRE",item)

            node = node.frontier.pop()

            for priority, item in node.frontier.heap:
                print("POST", item)

            print("Nodo Corrente: ", node)
            print(count)

            if problem.goal_test((node.robot_node, (node.room)), node):
                end_time_alg = time.time()
                time_alg = end_time_alg - start_time_alg

                return node, dirty_count, Vdirty_count, rooms, transformed_images, time_alg

            node.explored.add(node.room)

            for child, stato in node.expand(problem, node, deterministic=True, GreedyAlt=True):
                if child != None and child.room not in node.explored and not node.frontier.__contains__(
                        (child.robot_node, child.room)):
