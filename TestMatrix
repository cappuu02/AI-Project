    def robot_stuck(node, explored):
        robot_row, robot_col = node.room
    
        # Verifica se il robot è bloccato in tutte e quattro le direzioni
        up_blocked = robot_row == 0 or find_letter_position(node, node.room[0] - 1, node.room[1]) == "X" or (node.room[0] - 1, node.room[1]) in explored
        down_blocked = robot_row >= len(rooms) - 1 or find_letter_position(node, node.room[0] + 1, node.room[1]) == "X" or (node.room[0] + 1, node.room[1]) in explored
        left_blocked = robot_col == 0 or find_letter_position(node, node.room[0], node.room[1] - 1) == "X" or (node.room[0], node.room[1] - 1) in explored
        right_blocked = robot_col >= len(rooms) - 1 or find_letter_position(node, node.room[0], node.room[1] + 1) == "X" or (node.room[0], node.room[1] + 1) in explored

        if(up_blocked == True and down_blocked == True and left_blocked == True and right_blocked == True):

            if(up_blocked == True and robot_row != 0 and find_letter_position(node, node.room[0] - 1, node.room[1]) != "X"):
                node.explored.remove((node.room[0] - 1, node.room[1]))
                print("Ho rimosso",(node.room[0] - 1, node.room[1]),"dagli esplorati per permettere al robot di spostarsi")
            if(down_blocked == True and robot_row < len(rooms) - 1 and find_letter_position(node, node.room[0] + 1, node.room[1]) != "X"):
                node.explored.remove((node.room[0] + 1, node.room[1]))
                print("Ho rimosso",(node.room[0] + 1, node.room[1]),"dagli esplorati per permettere al robot di spostarsi")
            if(left_blocked == True and robot_col != 0 and find_letter_position(node, node.room[0], node.room[1] - 1) != "X"):
