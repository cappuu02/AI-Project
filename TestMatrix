                print("Ho rimosso",(node.room[0], node.room[1] - 1),"dagli esplorati per permettere al robot di spostarsi")
            if(right_blocked == True and robot_col < len(rooms) - 1 and find_letter_position(node, node.room[0], node.room[1] + 1) != "X"):
