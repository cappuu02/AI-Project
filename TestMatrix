    def copy_priority_queue(priority_queue):
        copied_queue = PriorityQueue(f=priority_queue.f)
        for _, item in priority_queue.heap:
            copied_queue.append(item)
        return copied_queue

    def count_dirty_rooms(rooms):
        dirty_count = 0
