class Node:
    def __init__(self, robot_node, room, parent = None, action = None, path_cost = 0):
        self.robot_node = robot_node
        self.room = room
        self.parent = parent
        self.action = action
        self.path_cost = path_cost

    def __repr__(self):
      return f"<Node ('{self.robot_node}', {self.room})>"


    def expand(self, problem):
        return [(self.child_node(problem, action))#uno per la posizione uno per il nodo effettivo
          for action in problem.actions(self.robot_node, self.room)]#mi dice quali azioni posso fare dal nodo attuale
          #for viene eseguito prima del return perchè result lavora con action



    def child_node(self, problem, action):
        next_state = problem.result(self, action)#in next state salviamo il nodo figlio che ci viene dato dalla funzione result

        if next_state is None:
            print(self)
            print(self.robot_node)
            print("PORCODIO")
            stato = ("'" + self.robot_node + "'", {self.room})
            print(stato)
            return self, stato  # Se next_state è None, restituisci None sia per il nodo che per lo stato

        next_node = Node(next_state[0], next_state[1], self, action, problem.path_cost(self.path_cost, self, action, next_state))
        #next_node = Node(next_state[0], next_state[1], self, action, problem.path_cost(self.path_cost, self, action, next_state))#creazione nodo figlio che abbiamo scoperto
        print("----------------------------------")
        print(next_node)
        print(next_state)
        print("----------------------------------")
        

        return next_node, next_state

    def solution(self):
        return [node.action for node in self.path()[1:]]

    def path(self):
        node, path_back = self, []
        while node:
            path_back.append(node)
            node = node.parent
        return list(reversed(path_back))



def breadth_search_first(problem):
    initial_state = find_initial_position(problem.rooms)
    print(initial_state)
    state, room = initial_state
    initial_node = Node(state, room)
    if problem.goal_test(initial_state):
        return initial_node
    #crea la frontiera e aggiungi il primo nodo (initial)
    frontier = deque([initial_node])
    print(frontier)
    #lista dei nodi esplorati
    explored = set()

    #finchè c'è qualcosa nella frontiera
    while frontier:
        node = frontier.popleft()#toglie primo nodo dalla frontiera
        print("Current Node:", node)  # Stampa il nodo corrente
        explored.add(node.robot_node) #aggiungi il nodo a quelli esplorati
        print("Frontiera:", frontier)
        print('--')
        print("Esplorati:", explored)
        print('--')
        for child, stato in node.expand(problem):
          print("AHHHHHH")
          print(child)
          print("AHHHHHH")
          if child not in explored and child not in frontier:
                if problem.goal_test(stato):
                    print("Last Expanded: ", node)
                    print("# explored BFS: ", len(explored))
                    return child
                frontier.append(child)
    return None

#Funzione che Ritorna la posizione all'interno della matrice di S
def find_initial_position(rooms):
    for row_idx, row in enumerate(rooms):
        for col_idx, cell in enumerate(row):
            if cell == "S":
                position = (row_idx, col_idx)  # Aggiungi 1 agli indici per ottenere le coordinate basate su 1
                return ("S", position)  # Ritorna una tupla con il simbolo e le coordinate

    return None

def find_letter_position(rooms, row, col):
    return rooms[row][col]

def update_letter_position(rooms, row, col, new_letter):
    rooms[row][col] = new_letter


